# Copy to .env and adjust for local (non-Docker) runs.
# Docker Compose sets these automatically for the api service -- see docker-compose.yml.

# Where the api service can reach Ollama.
# - Local (non-Docker) runs: http://localhost:11434 (default when unset).
# - Docker Compose default (recommended -- see README "Quickstart"): the api
#   container reaches natively-run Ollama on the host via
#   http://host.docker.internal:11434 (docker-compose.yml sets this
#   automatically; only set OLLAMA_BASE_URL here if you need to override it).
# - Fully-dockerized Ollama (--profile dockerized-ollama): http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434

# Where the api service can reach Qdrant. Unset -> in-memory Qdrant (fine for local dev/tests).
QDRANT_URL=http://localhost:6333

# Optional: override which config/*.yaml file is loaded (defaults to config/default.yaml).
CONFIG_PATH=config/default.yaml

# Only needed if you flip config/default.yaml llm.provider to "anthropic" or "openai".
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Bearer keys accepted by the /chat and /sources endpoints (see
# app/security/auth.py). Format: comma-separated "key:agent_id" pairs, one
# per provisioned support agent, e.g.:
# AGENT_API_KEYS=sk-abc123:agent_alice,sk-def456:agent_bob
# Required whenever config/default.yaml auth.enabled is true (the default).
# Leaving it unset with auth.enabled=true means no key will ever match, so
# every request gets a 401 -- set auth.enabled=false instead for local
# dev/tests that don't want to configure keys at all.
# AGENT_API_KEYS=

# Only needed if you want /chat turns shipped to Langfuse
# (config/default.yaml observability.provider=langfuse, the default).
# Leaving these unset does not break anything -- the Langfuse SDK detects the
# missing credentials, logs a warning, and no-ops tracing instead of raising.
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=
